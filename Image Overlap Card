<!DOCTYPE html>
<html>
<head>
 <title>Image Overlay</title>

 <style>
   .card {
     position: relative;
     width: 400px;
     height: 300px;
   }

   img:nth-child(1) {
     height: 200px;
     width: 300px;
     position: absolute;
     left: 50px;
     top: 50px;
     z-index: 1;
     border-radius: 10px;
   }

   img:nth-child(2) {
     height: 150px;
     width: 250px;
     position: absolute;
     left: 100px;
     top: 80px;
     z-index: 2;
     border-radius: 10px;
   }
 </style>
</head>

<body>

 <div class="card">
   <img src="./images/car-2.jpeg" alt="">
   <img src="./images/car.jpeg" alt="">
   <h2>Car</h2>
   <p>This is car</p>
 </div>

</body>
</html>


